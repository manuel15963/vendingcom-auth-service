-- ============================================================
-- 8. VALIDACIÓN FINAL
-- ============================================================

SELECT
    table_name
FROM information_schema.tables
WHERE table_schema = 'public'
  AND table_name LIKE 'auth_%'
ORDER BY table_name;

SELECT
    u.user_id,
    u.username,
    u.email,
    u.full_name,
    u.user_status,
    r.role_code,
    r.role_name,
    ur.assignment_status
FROM auth_users u
LEFT JOIN auth_user_roles ur
    ON ur.user_id = u.user_id
LEFT JOIN auth_roles r
    ON r.role_id = ur.role_id
WHERE u.username = 'admin';

